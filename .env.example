# This is copied from .env.example

##############################################################################
#                   PathSight GLOBAL configuration                           #
##############################################################################

# ── Repo/Project root override ──────────────────────────
PATHSIGHT_ROOT=path/to/your/repo/pathsight

##############################################################################
#                   PathSight MODEL configuration                            #
##############################################################################

# ── Data pipeline ───────────────────────────────────────────────────────────
PCAM_IMAGE_SIZE=96
PCAM_BATCH_SIZE=32
PCAM_SEED=42

# ── Training (recall-tuned defaults) ────────────────────────────────────────
PCAM_EPOCHS=10
PCAM_LEARNING_RATE=1e-3
# val_pr_auc tracks the high-recall region of the PR curve; better than val_auc
# (ROC-AUC) for medical models where missing positives is the costly error.
PCAM_EARLY_STOP_MONITOR=val_pr_auc
PCAM_EARLY_STOPPING_PATIENCE=5
PCAM_EARLY_STOP_MODE=max
MODEL_METRICS=["accuracy", "auc", "pr_auc", "precision", "recall"]

# ── Augmentation strength (Tellez 2019 H&E recipe) ──────────────────────────
# Override any of these to experiment without touching code.
PCAM_AUG_BRIGHTNESS=0.15
PCAM_AUG_CONTRAST=0.15
PCAM_AUG_SATURATION=0.15
PCAM_AUG_HUE=0.04
PCAM_AUG_ZOOM_MIN_AREA=0.9
PCAM_AUG_USE_ROT90=1

##############################################################################
#                 PathSight BACKEND & API configuration                      #
##############################################################################
# --- Backend & API env ---
APP_PORT=8000
BEST_MODEL_PATH=backend/baseline_nb.keras # Only use this for local testing without Docker.

# --- Docker & GCP related configuration for deployment ---
DOCKER_IMAGE_NAME=pathsight-backend
DOCKER_LOCAL_PORT=8080
GCP_PROJECT=your_project_id
GCP_REGION=europe-central2
DOCKER_REPO_NAME=pathsight
MODEL_BUCKET_NAME=pathsight-models-wagon-bootcamp-489111  # GCS bucket containing best_model.keras (required for Docker build)


##############################################################################
#                 PathSight FRONTEND configuration                           #
##############################################################################

# Add Frontend env specific here
